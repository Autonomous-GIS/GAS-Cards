{
  "service": "GAS",
  "version": "1.0.0",
  "request": "GetCapabilities",
  "title": "Geospatial Agentic Services from GIBD Lab at Penn State",
  "description": "Demonstration API for GAS agents in a WMS-like style with JSON payloads.",
  "provider": {
	    "name": "Geoinformation and Big Data Research Lab (GIBD)",
		"website": "https://giscience.psu.edu",
		"contact": {
			"name": "Zhenlong Li",
			"email":"zhenlong@psu.edu"
		}
   },
  "endpoints": {
    "GetCapabilities": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=GetCapabilities",
    "DescribeAgent": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent={agentName}"
  },
  "agents": [
    {
      "agentName": "DataRetrieverAgent",
      "describeUrl": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent=data_retriever_agent"
    },
    {
      "agentName": "MapProjectionAgent",
      "describeUrl": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent=map_projection_agent"
    },
    {
      "agentName": "MappingAgent",
      "describeUrl": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent=mapping_agent"
    },
    {
      "agentName": "PasdaDiscoveryAgent",
      "describeUrl": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent=pasda_agent"
    },
    {
      "agentName": "RasterAgent",
      "describeUrl": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent=raster_agent"
    },
    {
      "agentName": "VectorAnalysisAgent",
      "describeUrl": "https://autonomous-gis.github.io/GAS-Store?SERVICE=GAS&VERSION=1.0.0&REQUEST=DescribeAgent&agent=vector_analysis_agent"
    }
  ]
}