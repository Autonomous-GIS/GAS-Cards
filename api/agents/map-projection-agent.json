from datetime import datetime

# ---------------------------------------------------------
# REUSABLE TEMPLATE: GeoA2A Profile Metadata Builder
# ---------------------------------------------------------

def build_geo_extension(
    agent_classification: str,  # "native", "adapted", or "custom"
    agent_type: str,            # e.g., "data_discovery", "spatial_analysis"
    domain_scope: list,         # e.g., ["geospatial", "disaster"]
    supported_data_types: list, # e.g., ["vector", "raster", "table"]
    supported_formats: list,    # e.g., ["GeoJSON", "Shapefile", "CSV"]
    supported_crs: list,        # e.g., ["EPSG:4326", "Any"]
    geometry_types: list,       # e.g., ["Point", "Polygon"]
    validation_capabilities: list, # e.g., ["crs_check", "schema_check"]
    policy_roles: list,         # e.g., ["all"] or ["internal_only"]
    skills_list: list           # The list of hierarchical skill dictionaries
):
    """
    Constructs the mandatory GeoA2A Extension payload for the A2A AgentCard.
    Includes all Required and Recommended fields from the GAS Specification (v0.1).
    """
    return {
        "name": "geoa2a",
        "uri": "https://geoa2a.org/profile/v0.1",
        "description": f"GeoA2A profile metadata for {agent_type} agent",
        "data": {
            # 1. Admission & Core Profile Requirements
            "admission_tier": 2, 
            "agent_classification": agent_classification,
            "agent_type": agent_type,
            "trust_level": "medium", 
            "status": "active",
            "last_updated": datetime.now().strftime("%Y-%m-%d"),
            "provider": "Your Lab/Organization",
            
            # 2. Capabilities & Constraints (Recommended fields included as empty if unused)
            "domain_scope": domain_scope,
            "supported_data_types": supported_data_types,
            "supported_formats": supported_formats,
            "supported_crs": supported_crs,
            "geometry_types": geometry_types,
            "raster_types": [],                  # Recommended: keep empty if not applicable
            "spatial_extent_limit": None,        # Recommended: keep null if global
            "scale_or_resolution_constraints": None, # Recommended
            "schema_requirements": None,         # Recommended
            
            # 3. Validation & Traceability Requirements
            "validation_capabilities": validation_capabilities,
            "provenance_support": True,          # Mandatory for Tier 2+
            "reproducibility_support": True,     # Mandatory for Tier 2+
            
            # 4. Governance Policy Block
            "policy": {
                "allowed_roles": policy_roles,
                "restricted_operations": [],
                "human_approval_required_for": [],
                "output_review_required": False
            },
            
            # 5. Formal Hierarchical Skills
            "geospatial_skills": skills_list
        }
    }

# ---------------------------------------------------------
# REUSABLE TEMPLATE: Hierarchical Skill Builder
# ---------------------------------------------------------

def build_skill_declaration(
    skill_id: str,
    task_families: list,
    supported_operations: list,
    input_requirements: dict,
    output_specification: dict,
    execution_mode: str = "workflow"
):
    """
    Constructs a single skill object matching the Generic skill declaration fields.
    """
    return {
        "skill_id": skill_id,
        "task_families": task_families,
        "supported_operations": supported_operations,
        "input_requirements": input_requirements,
        "output_specification": output_specification,
        "execution_mode": execution_mode,
        
        # Recommended fields left empty for safe parsing
        "spatial_constraints": None,
        "optional_parameters": [],
    }

# ---------------------------------------------------------
# REUSABLE TEMPLATE: Standardized Artifact Builder
# ---------------------------------------------------------

def build_geospatial_artifact_metadata(
    artifact_class: str, # e.g., "feature_collection_reference", "validation_artifact"
    crs: str = None, 
    data_type: str = None,
    bbox: list = None
):
    """
    Ensures outputs include the Mandatory Scientific Context.
    """
    metadata = {
        "artifact_class": artifact_class,
        "provenance_generated": True
    }
    if crs:
        metadata["crs"] = crs
    if data_type:
        metadata["data_type"] = data_type
    if bbox:
        metadata["bbox"] = bbox
        
    return metadata




from datetime import datetime
from typing import List, Dict, Any

def build_provenance_record(
    agent_id: str,
    task_id: str,
    skill_name: str,
    operations_executed: List[str],
    start_time: str,
    inputs_used: List[str],
    parameters: Dict[str, Any]
) -> dict:
    """
    Builds a GAS-compliant provenance metadata block.
    """
    return {
        "record_type": "provenance",
        "task_id": task_id,
        "agent_id": agent_id,
        "skill_name": skill_name,
        "operations_executed": operations_executed,
        "execution_window": {
            "start": start_time,
            "end": datetime.now().isoformat()
        },
        "inputs_referenced": inputs_used,
        "parameters_applied": parameters,
        "status": "completed"
    }

def build_validation_record(
    validator_id: str,
    stage: str,          # "input", "process", or "output"
    overall_status: str, # "pass", "warning", or "failed"
    checks: List[dict]   # List of specific checks e.g., {"name": "crs_check", "status": "pass"}
) -> dict:
    """
    Builds a GAS-compliant validation metadata block.
    """
    return {
        "record_type": "validation",
        "validator_id": validator_id,
        "validation_stage": stage,
        "overall_status": overall_status,
        "checks_performed": checks
    }


